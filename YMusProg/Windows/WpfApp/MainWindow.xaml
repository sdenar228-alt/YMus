<Window x:Class="YMus.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:models="clr-namespace:YMus.Wpf.Models"
        mc:Ignorable="d"
        Width="1248"
        Height="704"
        MinWidth="1080"
        MinHeight="650"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="CanResize"
        Background="#050505"
        Icon="Assets/ymus.ico"
        Title="YMus">

    <Window.Resources>
        <SolidColorBrush x:Key="Yellow" Color="#FFD400"/>
        <SolidColorBrush x:Key="Text" Color="#F5F2E9"/>
        <SolidColorBrush x:Key="Muted" Color="#A6A6A6"/>
        <SolidColorBrush x:Key="Panel" Color="#B20F0F0F"/>
        <SolidColorBrush x:Key="Line" Color="#2C2C2C"/>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource Text}"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="TextOptions.TextFormattingMode" Value="Display"/>
        </Style>

        <Style x:Key="MutedText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource Muted}"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>

        <Style x:Key="KickerText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource Yellow}"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>

        <Style x:Key="PanelBorder" TargetType="Border">
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Background" Value="{StaticResource Panel}"/>
            <Setter Property="BorderBrush" Value="#303030"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
        </Style>

        <Style x:Key="GlassButton" TargetType="Button">
            <Setter Property="Foreground" Value="{StaticResource Text}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="Background" Value="#171717"/>
            <Setter Property="BorderBrush" Value="#33FFFFFF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                CornerRadius="8"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="BorderBrush" Value="#88FFD400"/>
                                <Setter TargetName="Root" Property="Background" Value="#222018"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#302A10"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource GlassButton}">
            <Setter Property="Foreground" Value="#090909"/>
            <Setter Property="Background" Value="#FFD400"/>
            <Setter Property="BorderBrush" Value="#FFE66A"/>
            <Setter Property="Padding" Value="22,12"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#FFD400" BlurRadius="22" ShadowDepth="0" Opacity="0.22"/>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="NavButton" TargetType="Button" BasedOn="{StaticResource GlassButton}">
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Foreground" Value="#CFCFCF"/>
            <Setter Property="Padding" Value="15,13"/>
        </Style>

        <Style x:Key="ActiveNavButton" TargetType="Button" BasedOn="{StaticResource NavButton}">
            <Setter Property="Foreground" Value="{StaticResource Yellow}"/>
            <Setter Property="Background" Value="#2A231000"/>
            <Setter Property="BorderBrush" Value="#66FFD400"/>
        </Style>

        <Style x:Key="SwitchBox" TargetType="CheckBox">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Border x:Name="Track" Width="40" Height="21" CornerRadius="11" Background="#202020" BorderBrush="#777" BorderThickness="1">
                            <Ellipse x:Name="Thumb" Width="15" Height="15" Fill="#DADADA" HorizontalAlignment="Left" Margin="3,0,0,0"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Track" Property="Background" Value="#FFD400"/>
                                <Setter TargetName="Track" Property="BorderBrush" Value="#FFD400"/>
                                <Setter TargetName="Thumb" Property="Fill" Value="#FFFFFF"/>
                                <Setter TargetName="Thumb" Property="HorizontalAlignment" Value="Right"/>
                                <Setter TargetName="Thumb" Property="Margin" Value="0,0,3,0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid ClipToBounds="True">
        <Grid.Background>
            <RadialGradientBrush Center="0.48,0.12" RadiusX="0.95" RadiusY="1">
                <GradientStop Color="#181606" Offset="0"/>
                <GradientStop Color="#070707" Offset="0.55"/>
                <GradientStop Color="#050505" Offset="1"/>
            </RadialGradientBrush>
        </Grid.Background>

        <Canvas x:Name="AnimatedBackground" IsHitTestVisible="False" Opacity="0.75">
            <Canvas.RenderTransform>
                <TranslateTransform x:Name="BackgroundTransform"/>
            </Canvas.RenderTransform>
            <Path Stroke="#13FFD400" StrokeThickness="1" Data="M-90,154 L1320,154 M-90,242 L1320,242 M-90,330 L1320,330 M-90,418 L1320,418 M-90,506 L1320,506 M-90,594 L1320,594"/>
            <Path Stroke="#10FFD400" StrokeThickness="1" Data="M180,-120 L-80,760 M420,-120 L160,760 M660,-120 L400,760 M900,-120 L640,760 M1140,-120 L880,760 M1380,-120 L1120,760"/>
            <Ellipse x:Name="GlowOne" Width="360" Height="360" Canvas.Left="-130" Canvas.Top="430" Fill="#16FFD400"/>
            <Ellipse x:Name="GlowTwo" Width="420" Height="420" Canvas.Left="920" Canvas.Top="-190" Fill="#10FFD400"/>
        </Canvas>

        <Border Height="2" VerticalAlignment="Top" Background="{StaticResource Yellow}"/>

        <Grid ColumnDefinitions="216,*">
            <Border Background="#92090909" BorderBrush="#303030" BorderThickness="0,0,1,0">
                <Grid RowDefinitions="68,*,174">
                    <StackPanel Orientation="Horizontal" Margin="22,18,16,0">
                        <Border Width="38" Height="38" CornerRadius="19" Background="{StaticResource Yellow}">
                            <Image Source="Assets/ymus.png" Width="29" Height="29"/>
                        </Border>
                        <StackPanel Margin="12,0,0,0">
                            <TextBlock Text="YMus" FontSize="20" FontWeight="Bold"/>
                            <TextBlock Text="Менеджер расширения" Style="{StaticResource MutedText}"/>
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Grid.Row="1" Margin="22,36,16,0">
                        <Button Style="{StaticResource NavButton}" Margin="0,0,0,12">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="⌂" FontSize="18" Width="30"/>
                                <TextBlock Text="Обзор" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource NavButton}" Margin="0,0,0,12">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="◎" FontSize="18" Width="30"/>
                                <TextBlock Text="Браузеры" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource ActiveNavButton}" Margin="0,0,0,12">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="⚙" FontSize="17" Width="30"/>
                                <TextBlock Text="Настройки" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource NavButton}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="☷" FontSize="17" Width="30"/>
                                <TextBlock Text="Журнал" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>

                    <Grid Grid.Row="2" Margin="36,0,36,28">
                        <Ellipse Width="128" Height="38" Fill="#15FFD400" VerticalAlignment="Bottom"/>
                        <Ellipse Width="78" Height="22" Stroke="#66FFD400" StrokeThickness="1" VerticalAlignment="Bottom" Margin="0,0,0,15"/>
                        <Border Width="54" Height="54" CornerRadius="12" BorderBrush="#CCFFD400" BorderThickness="2" Background="#181A1402" VerticalAlignment="Bottom" Margin="0,0,0,50">
                            <TextBlock Text="▣" Foreground="{StaticResource Yellow}" FontSize="26" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </Grid>
                </Grid>
            </Border>

            <Grid Grid.Column="1" RowDefinitions="68,*">
                <Border x:Name="TopBar" Background="#680B0B0B" BorderBrush="#303030" BorderThickness="0,0,0,1" MouseLeftButtonDown="TopBar_MouseLeftButtonDown">
                    <Grid ColumnDefinitions="Auto,Auto,*,Auto,Auto,Auto,Auto,Auto" Margin="30,0,22,0">
                        <Border CornerRadius="8" Background="#14161616" BorderBrush="#283A3A3A" BorderThickness="1" Padding="12,6" VerticalAlignment="Center">
                            <TextBlock Text="{Binding VersionLabel}" Style="{StaticResource MutedText}"/>
                        </Border>
                        <Border Grid.Column="1" CornerRadius="8" Background="#14161616" BorderBrush="#283A3A3A" BorderThickness="1" Padding="12,6" Margin="14,0,0,0" VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal">
                                <Ellipse Width="7" Height="7" Fill="#54D85C" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding Status}" Style="{StaticResource MutedText}" Margin="8,0,0,0"/>
                            </StackPanel>
                        </Border>
                        <Button Grid.Column="3" Style="{StaticResource GlassButton}" Content="⟳  Проверить обновления" Command="{Binding CheckUpdatesCommand}" Foreground="{StaticResource Yellow}" BorderBrush="#55604400" Margin="0,0,14,0"/>
                        <Button Grid.Column="4" Style="{StaticResource GlassButton}" Content="⚙" Width="38" Padding="0" Margin="0,0,16,0"/>
                        <Border Grid.Column="5" Width="1" Height="30" Background="#303030" VerticalAlignment="Center"/>
                        <Button Grid.Column="6" Style="{StaticResource GlassButton}" Content="−" Width="34" Padding="0" Margin="14,0,8,0" Click="MinimizeButton_Click"/>
                        <Button Grid.Column="7" Style="{StaticResource GlassButton}" Content="×" Width="34" Padding="0" Click="CloseButton_Click"/>
                    </Grid>
                </Border>

                <Grid Grid.Row="1" ColumnDefinitions="*,296" Margin="30,22,30,24">
                    <Grid RowDefinitions="Auto,*,66">
                        <StackPanel>
                            <TextBlock Text="Настройки" FontSize="28" FontWeight="Bold"/>
                            <TextBlock Text="Управление установкой, обновлениями и поведением программы." Style="{StaticResource MutedText}" Margin="0,6,0,0"/>
                        </StackPanel>

                        <Border Grid.Row="1" Style="{StaticResource PanelBorder}" Padding="14" Margin="0,18,18,18">
                            <Grid RowDefinitions="46,46,46,46,46,46,46,46,46">
                                <Grid ColumnDefinitions="38,*,Auto">
                                    <TextBlock Text="⟳" Foreground="{StaticResource Yellow}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" Text="Автоматически обновлять расширение" VerticalAlignment="Center"/>
                                    <CheckBox Grid.Column="2" Style="{StaticResource SwitchBox}" IsChecked="{Binding AutoUpdateExtension}" VerticalAlignment="Center"/>
                                </Grid>
                                <Grid Grid.Row="1" ColumnDefinitions="38,*,Auto">
                                    <TextBlock Text="⌕" Foreground="{StaticResource Yellow}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" Text="Проверять обновления при запуске" VerticalAlignment="Center"/>
                                    <CheckBox Grid.Column="2" Style="{StaticResource SwitchBox}" IsChecked="{Binding CheckUpdatesOnStart}" VerticalAlignment="Center"/>
                                </Grid>
                                <Grid Grid.Row="2" ColumnDefinitions="38,*,Auto">
                                    <TextBlock Text="⏻" Foreground="{StaticResource Yellow}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" Text="Запускать YMus вместе с системой" VerticalAlignment="Center"/>
                                    <CheckBox Grid.Column="2" Style="{StaticResource SwitchBox}" IsChecked="{Binding StartWithSystem}" VerticalAlignment="Center"/>
                                </Grid>
                                <Grid Grid.Row="3" ColumnDefinitions="38,*,Auto">
                                    <TextBlock Text="⌄" Foreground="{StaticResource Yellow}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" Text="Сворачивать в трей" VerticalAlignment="Center"/>
                                    <CheckBox Grid.Column="2" Style="{StaticResource SwitchBox}" IsChecked="{Binding MinimizeToTray}" VerticalAlignment="Center"/>
                                </Grid>
                                <Grid Grid.Row="4" ColumnDefinitions="38,*,Auto">
                                    <TextBlock Text="♢" Foreground="{StaticResource Yellow}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" Text="Показывать уведомления об обновлениях" VerticalAlignment="Center"/>
                                    <CheckBox Grid.Column="2" Style="{StaticResource SwitchBox}" IsChecked="{Binding ShowUpdateNotifications}" VerticalAlignment="Center"/>
                                </Grid>
                                <Grid Grid.Row="5" ColumnDefinitions="38,*,220">
                                    <TextBlock Text="◌" Foreground="{StaticResource Yellow}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" Text="Тема интерфейса" VerticalAlignment="Center"/>
                                    <ComboBox Grid.Column="2" SelectedItem="{Binding Theme}" Background="#141414" Foreground="{StaticResource Text}">
                                        <ComboBoxItem Content="Темная"/>
                                        <ComboBoxItem Content="Системная"/>
                                    </ComboBox>
                                </Grid>
                                <Grid Grid.Row="6" ColumnDefinitions="38,*,220">
                                    <TextBlock Text="◎" Foreground="{StaticResource Yellow}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" Text="Язык интерфейса" VerticalAlignment="Center"/>
                                    <ComboBox Grid.Column="2" SelectedItem="{Binding Language}" Background="#141414" Foreground="{StaticResource Text}">
                                        <ComboBoxItem Content="Русский"/>
                                        <ComboBoxItem Content="English"/>
                                    </ComboBox>
                                </Grid>
                                <Grid Grid.Row="7" ColumnDefinitions="38,*,210,94">
                                    <TextBlock Text="▭" Foreground="{StaticResource Yellow}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" Text="Папка расширения" VerticalAlignment="Center"/>
                                    <TextBox Grid.Column="2" Text="{Binding ExtensionFolderDisplay, Mode=OneWay}" IsReadOnly="True" Background="#141414" Foreground="{StaticResource Text}" BorderBrush="#3B3B2C"/>
                                    <Button Grid.Column="3" Style="{StaticResource GlassButton}" Content="Изменить" Command="{Binding OpenPreparedFolderCommand}" Foreground="{StaticResource Yellow}" Margin="8,0,0,0"/>
                                </Grid>
                                <Grid Grid.Row="8" ColumnDefinitions="38,*,150,104">
                                    <TextBlock Text="↺" Foreground="{StaticResource Yellow}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" Text="Резервное копирование настроек" VerticalAlignment="Center"/>
                                    <Button Grid.Column="2" Style="{StaticResource GlassButton}" Content="Создать копию" Command="{Binding CreateBackupCommand}" Foreground="{StaticResource Yellow}"/>
                                    <Button Grid.Column="3" Style="{StaticResource GlassButton}" Content="Сбросить" Command="{Binding ResetSettingsCommand}" Margin="8,0,0,0"/>
                                </Grid>
                            </Grid>
                        </Border>

                        <Border Grid.Row="2" Style="{StaticResource PanelBorder}" Padding="18,14" Margin="0,0,18,0">
                            <Grid ColumnDefinitions="220,160,*">
                                <Button Style="{StaticResource PrimaryButton}" Content="▣  Сохранить изменения" Command="{Binding SaveSettingsCommand}"/>
                                <Button Grid.Column="1" Style="{StaticResource GlassButton}" Content="×  Отменить" Margin="18,0,0,0"/>
                                <TextBlock Grid.Column="2" Text="{Binding Status}" Style="{StaticResource MutedText}" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                    </Grid>

                    <Grid Grid.Column="1" RowDefinitions="*,174">
                        <Border Style="{StaticResource PanelBorder}" Padding="16">
                            <Grid RowDefinitions="Auto,*">
                                <StackPanel>
                                    <TextBlock Text="Интеграция с браузерами" FontSize="16" FontWeight="Bold"/>
                                    <TextBlock Text="Состояние подключения расширения" Style="{StaticResource MutedText}" Margin="0,5,0,0"/>
                                </StackPanel>
                                <ItemsControl Grid.Row="1" ItemsSource="{Binding Browsers}" Margin="0,16,0,0">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate DataType="{x:Type models:BrowserItem}">
                                            <Border CornerRadius="8" BorderBrush="#24383838" BorderThickness="1" Background="#10141414" Padding="12" Margin="0,0,0,10">
                                                <Grid ColumnDefinitions="42,*,Auto">
                                                    <Border Width="36" Height="36" CornerRadius="8" Background="#202020">
                                                        <Image Source="{Binding IconPath}" Width="28" Height="28"/>
                                                    </Border>
                                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold"/>
                                                        <StackPanel Orientation="Horizontal">
                                                            <Ellipse Width="6" Height="6" Fill="{Binding ConnectionBrush}" VerticalAlignment="Center"/>
                                                            <TextBlock Text="{Binding ConnectionStatus}" Foreground="{Binding ConnectionBrush}" FontSize="12" Margin="6,0,0,0"/>
                                                        </StackPanel>
                                                    </StackPanel>
                                                    <TextBlock Grid.Column="2" Text="›" Foreground="{StaticResource Muted}" FontSize="22" VerticalAlignment="Center"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Grid>
                        </Border>

                        <Border Grid.Row="1" Style="{StaticResource PanelBorder}" Padding="16" Margin="0,18,0,0">
                            <Grid RowDefinitions="Auto,*,Auto">
                                <StackPanel>
                                    <TextBlock Text="Журнал" FontSize="16" FontWeight="Bold"/>
                                    <TextBlock Text="Последние действия программы" Style="{StaticResource MutedText}"/>
                                </StackPanel>
                                <ItemsControl Grid.Row="1" ItemsSource="{Binding Logs}" Margin="0,12,0,0">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid ColumnDefinitions="52,56,*" Margin="0,0,0,6">
                                                <TextBlock Text="{Binding Stamp}" Style="{StaticResource MutedText}"/>
                                                <TextBlock Grid.Column="1" Text="{Binding Level}" Foreground="{StaticResource Yellow}" FontSize="10" FontWeight="Bold"/>
                                                <TextBlock Grid.Column="2" Text="{Binding Message}" Style="{StaticResource MutedText}" TextWrapping="Wrap"/>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <Button Grid.Row="2" Style="{StaticResource GlassButton}" Content="Управление браузерами  ↗" Command="{Binding InstallExtensionCommand}" Foreground="{StaticResource Yellow}"/>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </Grid>
        </Grid>

        <Border x:Name="StartupOverlay" Background="#F2070707">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <Border Width="82" Height="82" CornerRadius="41" Background="{StaticResource Yellow}">
                    <Image Source="Assets/ymus.png" Width="58" Height="58"/>
                </Border>
                <TextBlock Text="YMus" FontSize="32" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,16,0,0"/>
                <TextBlock Text="Загружаем менеджер расширения" Style="{StaticResource MutedText}" HorizontalAlignment="Center" Margin="0,4,0,14"/>
                <ProgressBar Width="150" Height="3" IsIndeterminate="True" Foreground="{StaticResource Yellow}" Background="#29250C"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
